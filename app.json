{
  "expo": {
    "name": "Skana",
    "slug": "skana",
    "version": "1.0.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0D1B2A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.skana.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Skana needs camera access to photograph skin lesions for AI screening.",
        "NSPhotoLibraryUsageDescription": "Skana needs photo access to analyze existing images of skin lesions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1B2A"
      },
      "package": "com.skana.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-image-picker",
      "expo-camera",
      "expo-asset"
    ]
  }
}
